{
  "manifest_version": 3,
  "name": "Lighthouse",
  "version": "1.3",
  "description": "A lightweight, modular text selection tooltip extension.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "favicon"
  ],
  "host_permissions": [
    "https://api.coinbase.com/*",
    "https://translate.googleapis.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["src/content/styles.css"],
      "js": [
        "src/utils/utils.js",
        "src/utils/data.js",
        "src/modules/math.js",
        "src/modules/actions.js",
        "src/utils/config.js",
        "src/modules/state.js",
        "src/modules/selection.js",
        "src/modules/api.js",
        "src/modules/markers.js",
        "src/modules/handles.js",
        "src/modules/ui.js",
        "src/content/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}